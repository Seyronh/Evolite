{
  "name": "evolite",
  "description": "A lightweight and efficient genetic algorithm library for TypeScript and JavaScript.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "private": false,
  "homepage": "https://github.com/Seyronh/Evolite",
  "version": "0.0.0-semantic-release",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Seyronh/Evolite.git"
  },
  "bugs": {
    "url": "https://github.com/Seyronh/Evolite/issues"
  },
  "files": [
    "LICENSE",
    "README.md",
    "dist",
    "package.json",
    "package-lock.json"
  ],
  "license": "MIT",
  "author": {
    "name": "Seyronh"
  },
  "keywords": [
    "Genetic Algorithm",
    "Optimization"
  ],
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --production --sourcemap --packages external && bun run build:declaration",
    "build:declaration": "tsc --project tsconfig.json",
    "test": "bun test --concurrent --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix && prettier --write .",
    "prepare": "lint-staged"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@eslint/markdown": "^8.0.3",
    "@types/bun": "latest",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jiti": "^2.7.0",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.5",
    "typescript-eslint": "^8.63.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "lint-staged": {
    "*.{ts,js}": "eslint --cache --fix",
    "*.{ts,js,css,md}": "prettier --write",
    "*.js": "eslint --cache --fix",
    "*.{js,css,md}": "prettier --write"
  }
}
